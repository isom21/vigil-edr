VIGIL_DEBUG=true
# Runtime DSN — the manager connects as `vigil_manager`, which (since
# M16.a fixed) is a non-superuser owner of the `vigil` database. The
# matching password is set in deploy/postgres-init.sql.
VIGIL_PG_DSN=postgresql+asyncpg://vigil_manager:vigil_dev_password@localhost:5432/vigil
# Audit-writer DSN — used by the chain verifier and audit-table
# migrations. The role owns `audit_log` and has full rights on it;
# the runtime VIGIL_PG_DSN above keeps only SELECT + INSERT.
VIGIL_PG_DSN_AUDIT=postgresql+asyncpg://vigil_audit_writer:please-set-during-install@localhost:5432/vigil
# Password used by the M16.a (fixed) migration when creating /
# rotating the vigil_audit_writer role. install.sh writes this once
# and reuses it for VIGIL_PG_DSN_AUDIT.
VIGIL_AUDIT_OWNER_PASSWORD=please-set-during-install
# HMAC key for the audit chain. Required for tamper-evident audit;
# rows written without it stay in the pre-chain era. Production
# operators should externalize this (HSM / KMS / vault) — co-locating
# it with the manager means a manager-host compromise can rewrite
# history undetected.
VIGIL_AUDIT_HMAC_KEY=please-generate-32-bytes-of-hex
VIGIL_OPENSEARCH_URL=http://localhost:9200
VIGIL_KAFKA_BROKERS=localhost:19092
# M12.e re-enrollment anomaly detector window. Hosts re-enrolling
# under an existing hostname within this many seconds raise a HIGH
# alert for triage. Default 3600 s = 1 h.
VIGIL_REENROLLMENT_WINDOW_SECONDS=3600
VIGIL_JWT_SECRET=please-generate-a-secret-of-at-least-16-chars
VIGIL_CA_MASTER_KEY=please-generate-a-secret-of-at-least-32-chars!!
VIGIL_GRPC_LISTEN=0.0.0.0:50051

# MinIO (Jobs engine artifact store). Defaults match deploy/docker-compose.yml.
VIGIL_MINIO_ENDPOINT=localhost:9000
VIGIL_MINIO_ACCESS_KEY=vigil
VIGIL_MINIO_SECRET_KEY=vigil_dev_password
VIGIL_MINIO_SECURE=false
